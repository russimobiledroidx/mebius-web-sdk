{
  "name": "mebius-web-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Mebius Client SDK for the web — monorepo (@mebius-io/web, @mebius-io/react, @mebius-io/react-native)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check:abstraction": "node scripts/check-abstraction.mjs",
    "pack:all": "turbo run build && pnpm -r --filter \"./packages/*\" exec pnpm pack --pack-destination ../..",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
