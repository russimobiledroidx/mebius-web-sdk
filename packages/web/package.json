{
  "name": "@mebius-io/web",
  "version": "0.1.2",
  "description": "Mebius Client SDK for the web — live streaming, simple API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/russimobiledroidx/mebius-web-sdk.git",
    "directory": "packages/web"
  },
  "scripts": {
    "build": "tsup && node scripts/build-standalone.mjs",
    "build:standalone": "node scripts/build-standalone.mjs",
    "prepack": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "hls.js": "^1.5.18"
  },
  "peerDependencies": {
    "flv.js": "^1.6.2"
  },
  "peerDependenciesMeta": {
    "flv.js": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mebius",
    "live",
    "streaming",
    "webrtc",
    "video",
    "sdk"
  ]
}
