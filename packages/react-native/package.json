{
  "name": "@mebius-io/react-native",
  "version": "0.1.2",
  "description": "Mebius Client SDK for React Native — broadcast and watch, backed by react-native-webrtc.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/russimobiledroidx/mebius-web-sdk.git",
    "directory": "packages/react-native"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-webrtc": ">=118"
  },
  "peerDependenciesMeta": {
    "react-native-webrtc": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "react": "^18.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mebius",
    "react-native",
    "live",
    "streaming"
  ]
}
