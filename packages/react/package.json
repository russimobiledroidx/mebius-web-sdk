{
  "name": "@mebius/react",
  "version": "0.1.0",
  "description": "React hooks for the Mebius Web SDK — a thin layer over @mebius/web.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@mebius/web": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "react": "^18.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["mebius", "react", "live", "streaming", "hooks"]
}
